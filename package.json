{
  "name": "repodoc",
  "displayName": "RepoDoc",
  "description": "Documentation, decision records, and kanban boards living inside your repo",
  "version": "0.1.0",
  "publisher": "jonathanturnock",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JonathanTurnock/repodoc"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repodoc",
          "title": "RepoDoc",
          "icon": "media/repodoc.svg"
        }
      ]
    },
    "views": {
      "repodoc": [
        {
          "id": "repodoc.boards",
          "name": "Boards",
          "icon": "media/repodoc.svg"
        },
        {
          "id": "repodoc.decisions",
          "name": "Decisions",
          "icon": "media/repodoc.svg"
        },
        {
          "id": "repodoc.docs",
          "name": "Docs",
          "icon": "media/repodoc.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "repodoc.boards",
        "contents": "No RepoDoc data found in this repo yet.\n[Initialize RepoDoc](command:repodoc.init)\nThis creates a `.repodoc/` folder with a starter board and decision record.",
        "when": "!repodoc.initialized"
      },
      {
        "view": "repodoc.decisions",
        "contents": "Decision records live in `.repodoc/decisions/` as numbered markdown files.\n[New Decision](command:repodoc.newDecision)",
        "when": "repodoc.initialized"
      },
      {
        "view": "repodoc.docs",
        "contents": "Documentation is rendered from the markdown tree under `docs/`.\nAdd a folder, drop in a `.md` file, and it shows up here."
      }
    ],
    "commands": [
      {
        "command": "repodoc.init",
        "title": "Initialize Workspace",
        "category": "RepoDoc"
      },
      {
        "command": "repodoc.refresh",
        "title": "Refresh",
        "category": "RepoDoc",
        "icon": "$(refresh)"
      },
      {
        "command": "repodoc.openBoard",
        "title": "Open Board",
        "category": "RepoDoc"
      },
      {
        "command": "repodoc.openDecision",
        "title": "Open Decision",
        "category": "RepoDoc"
      },
      {
        "command": "repodoc.openDoc",
        "title": "Open Doc",
        "category": "RepoDoc"
      },
      {
        "command": "repodoc.newBoard",
        "title": "New Board",
        "category": "RepoDoc",
        "icon": "$(add)"
      },
      {
        "command": "repodoc.newDecision",
        "title": "New Decision",
        "category": "RepoDoc",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "repodoc.newBoard",
          "when": "view == repodoc.boards",
          "group": "navigation@1"
        },
        {
          "command": "repodoc.newDecision",
          "when": "view == repodoc.decisions",
          "group": "navigation@1"
        },
        {
          "command": "repodoc.refresh",
          "when": "view =~ /^repodoc\\./",
          "group": "navigation@9"
        }
      ],
      "commandPalette": [
        {
          "command": "repodoc.openBoard",
          "when": "false"
        },
        {
          "command": "repodoc.openDecision",
          "when": "false"
        },
        {
          "command": "repodoc.openDoc",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  }
}
