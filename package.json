{
  "name": "repodoc",
  "displayName": "RepoDoc",
  "description": "Documentation, decision records, and kanban boards living inside your repo",
  "version": "0.4.0",
  "publisher": "flying-dice",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flying-dice/repodoc"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repodoc",
          "title": "RepoDoc",
          "icon": "media/repodoc.svg"
        }
      ]
    },
    "views": {
      "repodoc": [
        {
          "id": "repodoc.boards",
          "name": "Boards",
          "icon": "media/repodoc.svg"
        },
        {
          "id": "repodoc.decisions",
          "name": "Decisions",
          "icon": "media/repodoc.svg"
        },
        {
          "id": "repodoc.docs",
          "name": "Docs",
          "icon": "media/repodoc.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "repodoc.boards",
        "contents": "No RepoDoc data found in this repo yet.\n[Initialize RepoDoc](command:repodoc.init)\nThis creates a starter board under `boards/`, a first decision record, and a docs page.",
        "when": "!repodoc.initialized"
      },
      {
        "view": "repodoc.decisions",
        "contents": "Decision records live in `decisions/` as numbered markdown files.\n[New Decision](command:repodoc.newDecision)",
        "when": "repodoc.initialized"
      },
      {
        "view": "repodoc.docs",
        "contents": "Documentation is rendered from the markdown tree under `docs/`.\nAdd a folder, drop in a `.md` file, and it shows up here."
      }
    ],
    "commands": [
      {
        "command": "repodoc.init",
        "title": "Initialize Workspace",
        "category": "RepoDoc"
      },
      {
        "command": "repodoc.refresh",
        "title": "Refresh",
        "category": "RepoDoc",
        "icon": "$(refresh)"
      },
      {
        "command": "repodoc.openBoard",
        "title": "Open Board",
        "category": "RepoDoc",
        "icon": "$(open-preview)"
      },
      {
        "command": "repodoc.openDecision",
        "title": "Open Decision",
        "category": "RepoDoc"
      },
      {
        "command": "repodoc.openDoc",
        "title": "Open Doc",
        "category": "RepoDoc"
      },
      {
        "command": "repodoc.newBoard",
        "title": "New Board",
        "category": "RepoDoc",
        "icon": "$(add)"
      },
      {
        "command": "repodoc.newDecision",
        "title": "New Decision",
        "category": "RepoDoc",
        "icon": "$(add)"
      },
      {
        "command": "repodoc.installAgentSkill",
        "title": "Install Agent Skill",
        "category": "RepoDoc"
      },
      {
        "command": "repodoc.plantUmlStart",
        "title": "Start PlantUML Renderer (Docker)",
        "category": "RepoDoc"
      },
      {
        "command": "repodoc.plantUmlStop",
        "title": "Stop PlantUML Renderer (Docker)",
        "category": "RepoDoc"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "repodoc.newBoard",
          "when": "view == repodoc.boards",
          "group": "navigation@1"
        },
        {
          "command": "repodoc.newDecision",
          "when": "view == repodoc.decisions",
          "group": "navigation@1"
        },
        {
          "command": "repodoc.refresh",
          "when": "view =~ /^repodoc\\./",
          "group": "navigation@9"
        }
      ],
      "commandPalette": [
        {
          "command": "repodoc.openBoard",
          "when": "false"
        },
        {
          "command": "repodoc.openDecision",
          "when": "false"
        },
        {
          "command": "repodoc.openDoc",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "repodoc.openBoard",
          "when": "view == repodoc.boards && viewItem == repodoc.board",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "RepoDoc",
      "properties": {
        "repodoc.readingWidth": {
          "type": "string",
          "enum": [
            "normal",
            "wide",
            "full"
          ],
          "enumDescriptions": [
            "A compact 760px reading column",
            "A roomier 1100px reading column",
            "Use the full editor width"
          ],
          "default": "wide",
          "description": "Width of the reading column in the rendered Docs and Decision views."
        },
        "repodoc.plantUmlServer": {
          "type": "string",
          "default": "https://www.plantuml.com/plantuml",
          "markdownDescription": "PlantUML server used to render ```plantuml fences in Docs and Decisions (diagram source is sent to this server). Point it at a self-hosted instance for private diagrams, or set it empty to show PlantUML fences as plain code."
        },
        "repodoc.plantUmlDocker": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Render PlantUML through a **local Docker container** (`repodoc-plantuml`) managed by the extension, instead of the configured server \u2014 no diagram source leaves the machine. Requires Docker. The container starts on demand and stops when VS Code closes (or via *RepoDoc: Stop PlantUML Renderer*)."
        },
        "repodoc.plantUmlDockerImage": {
          "type": "string",
          "default": "plantuml/plantuml-server:jetty",
          "description": "Docker image used for the local PlantUML renderer."
        },
        "repodoc.plantUmlDockerPort": {
          "type": "number",
          "default": 8792,
          "description": "Local port the managed PlantUML container listens on."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "marked": "^15.0.7",
    "mermaid": "^11.16.0",
    "plantuml-encoder": "^1.4.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  }
}
